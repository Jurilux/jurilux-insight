# Copier vers .env (jamais commité) — sur le VPS : /opt/jurilux-api/.env
MEILI_MASTER_KEY=changez-moi-32-caracteres-mini
MEILI_URL=http://127.0.0.1:7700
MEILI_INDEX=chunks

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Routeur de modèle par SENSIBILITÉ (souveraineté par construction). Fournisseurs :
# anthropic (Claude) | mistral (API UE) | local (Ollama, air-gap). Par défaut tout sur
# anthropic. Un cabinet peut router les données privées (Vault) vers un modèle UE/local :
LLM_PROVIDER_PUBLIC=anthropic
LLM_PROVIDER_CONFIDENTIAL=anthropic
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-large-latest
# OLLAMA_URL=http://127.0.0.1:11434
# LOCAL_MODEL=llama3.1

PROMPT_VERSION=rebuild-2026-07-v1

# Backoffice admin : emails autorisés à accéder à /admin (séparés par des virgules)
ADMIN_EMAILS=contact@jurilux.lu

# SSO entreprise (OIDC) — optionnel. Vide = login mot de passe seul. Cf. deploy/AIRGAP.md.
# OIDC_ISSUER=https://idp.cabinet.lu/realms/jurilux
# OIDC_CLIENT_ID=jurilux
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=https://app.jurilux.lu/api/auth/oidc/callback
# FRONTEND_BASE_URL=https://app.jurilux.lu
